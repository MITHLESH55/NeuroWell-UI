# NeuroWell Backend Environment Configuration

# Server Configuration
NODE_ENV=development
PORT=3000

# Frontend URL for CORS
FRONTEND_URL=http://localhost:8080

# JWT Configuration
JWT_SECRET=neurowell_jwt_secret_key_change_in_production_2024
JWT_EXPIRES_IN=7d

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/neurowell

# Optional: MongoDB Atlas (for production)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/neurowell?retryWrites=true&w=majority

# JWT Secret (for future authentication)
# JWT_SECRET=your_jwt_secret_here

# Optional: Rate Limiting
# RATE_LIMIT_WINDOW=15
# RATE_LIMIT_MAX_REQUESTS=100